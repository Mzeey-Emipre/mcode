{
  "name": "mcode-desktop",
  "version": "0.0.1",
  "description": "Mcode AI agent orchestration desktop app",
  "main": "dist/main/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev-electron.mjs",
    "build": "bun scripts/build-main.mjs",
    "prod": "bun run build && npx electron .",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f",
    "dist": "bun run build && electron-builder --publish never",
    "test": "vitest run"
  },
  "dependencies": {
    "@mcode/contracts": "workspace:*",
    "@mcode/shared": "workspace:*",
    "@electron/rebuild": "^3.7.1",
    "uuid": "^11.1.0",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "@types/which": "^3.0.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "esbuild": "^0.27.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  },
  "build": {
    "appId": "com.mzeey.mcode",
    "productName": "Mcode",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  }
}
