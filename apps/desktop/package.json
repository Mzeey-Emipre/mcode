{
  "name": "mcode-desktop",
  "version": "0.0.1",
  "description": "Mcode AI agent orchestration desktop app",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prod": "electron-vite build && electron-vite preview",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f",
    "dist": "electron-builder --publish never",
    "test": "vitest run"
  },
  "dependencies": {
    "@mcode/shared": "workspace:*",
    "@electron/rebuild": "^3.7.1",
    "uuid": "^11.1.0",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/uuid": "^10.0.0",
    "@types/which": "^3.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  },
  "build": {
    "appId": "com.mzeey.mcode",
    "productName": "Mcode",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  }
}
